<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <PlatformTarget>x64</PlatformTarget>
    <AssemblyName>CncPreviewHandler</AssemblyName>
    <RootNamespace>CncPreviewHandler</RootNamespace>
    <Nullable>disable</Nullable>
    <LangVersion>9.0</LangVersion>

    <!--
      UseWPF and UseWindowsForms automatically pull in all WPF, WinForms,
      and WindowsFormsIntegration (ElementHost) assemblies â€” no manual
      <Reference> entries needed.
    -->
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>

    <!-- Strong-name signing removed â€” not required for COM registration -->
    <SignAssembly>false</SignAssembly>

    <!-- Prevent SDK auto-generating AssemblyInfo â€” we have our own in Properties/ -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>

  <!--
    PackageReference style â€” NuGet restores automatically on CI
    without packages.config or hint paths.
  -->
  <ItemGroup>
    <PackageReference Include="SharpShell"       Version="2.7.2"  />
    <PackageReference Include="HelixToolkit.Wpf" Version="2.25.0" />
  </ItemGroup>

</Project>
